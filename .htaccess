<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Chuyển hướng các link cũ còn sót lại
    RewriteRule ^restaurant-project/(.*)$ /$1 [R=301,L]

    # 1. Nếu yêu cầu là file hoặc thư mục có thật (như admin, public, index.php)
    # thì cho phép truy cập trực tiếp, không xử lý gì thêm
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. Làm đẹp đường dẫn (Tùy chọn)
    # Ví dụ: cho phép truy cập localhost/menu thay vì menu.php
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]

</IfModule>